# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pipenv
Pipfile.lock

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# -----------------------------------------------------------------------------
# DATA FILES (Large files should not be committed)
# -----------------------------------------------------------------------------
# Raw data
data/raw/*.csv
data/raw/*.parquet
data/raw/*.json

# Processed data (keep small samples, exclude full datasets)
data/processed/*.csv
data/processed/*.parquet
data/*.csv
data/*.parquet

# Model artifacts
models/*.pkl
models/*.h5
models/*.pt
models/*.bin
models/*.onnx

# -----------------------------------------------------------------------------
# IDE AND EDITOR
# -----------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Eclipse
.project
.settings/
.classpath

# PyCharm
*.ws

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.*~

# -----------------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# LOGS AND TEMPORARY FILES
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# AION SPECIFIC
# -----------------------------------------------------------------------------
# Local configuration
*.local
*.local.yaml
*.local.yml
*.env.local

# Database files
*.db
*.sqlite
*.sqlite3

# Export files
exports/
output/
