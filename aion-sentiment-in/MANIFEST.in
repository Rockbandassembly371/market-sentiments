#
# MANIFEST.in - Include files in source distribution
# ---------------------------------------------------
# This file specifies additional files to include in the source distribution.
# Used by setuptools when building sdist packages.
#
# =============================================================================

# Include README and documentation
include README.md
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include LICENSE
include NOTICE

# Include requirements files
include requirements.txt
include requirements-dev.txt

# Include demo and example files
include demo.py

# Include configuration files
include pyproject.toml
include setup.cfg
include .gitignore

# Include test files
recursive-include tests *.py

# Include source code
recursive-include src *.py

# Include data files for lexicons (if available)
recursive-include src/aion_sentiment/data *.txt
recursive-include src/aion_sentiment/data *.json

# Include model cards and documentation
include model_card.md

# Exclude unnecessary files
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude __pycache__
global-exclude .pytest_cache
global-exclude .coverage
global-exclude htmlcov
global-exclude *.egg-info
global-exclude dist
global-exclude build
global-exclude .eggs
global-exclude *.so
global-exclude *.dylib

# Exclude large files from source distribution
# (Models should be downloaded from HuggingFace, not included in package)
global-exclude models/*
global-exclude data/models/*
global-exclude *.bin
global-exclude *.pt
global-exclude *.pth
global-exclude *.onnx
global-exclude *.h5

# Exclude IDE and editor files
global-exclude .idea/*
global-exclude .vscode/*
global-exclude *.swp
global-exclude *.swo
global-exclude *~

# Exclude notebook checkpoints
global-exclude .ipynb_checkpoints/*
