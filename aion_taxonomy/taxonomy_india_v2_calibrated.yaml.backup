categories:
- id: macro_economy
  name: Macro Economy
  description: Broad economic indicators affecting the entire market
  subcategories:
  - id: monetary_policy
    name: Monetary Policy (RBI)
    description: RBI policy decisions, rates, liquidity, and monetary stance
    events:
    - id: macro_rbi_repo_hike
      name: RBI Repo Rate Hike
      seasonal_activation: false
      keywords:
      - repo rate hike
      - rbi hikes repo
      - hawkish rbi
      - rate increase
      base_impact:
        mild: -0.25
        normal: -0.55
        severe: -0.85
      default_impact: normal
      market_weight: 0.9
      event_volatility: null
      volatility_sensitive: false
      contextual_modifiers:
      - keywords:
        - surprise
        - unexpected
        - larger than expected
        impact_level: severe
      - keywords:
        - as expected
        - in line
        impact_level: mild
      sector_impacts:
        Financial Services:
          multiplier: 1.15
          bias: inverse
          beta_override: 1.25
          rationale: Funding costs rise; margins compress
        Banks:
          multiplier: 1.15
          bias: inverse
          beta_override: 1.25
          rationale: Funding costs rise; margins compress
        NBFC:
          multiplier: 1.15
          bias: inverse
          beta_override: 1.25
          rationale: Funding costs rise; margins compress
        Realty:
          multiplier: 1.25
          bias: inverse
          beta_override: 1.45
          rationale: Higher rates or weak demand pressure valuations
        Automobile and Auto Components:
          multiplier: 1.15
          bias: inverse
          rationale: EMI burden rises; demand softens
        FMCG:
          multiplier: 0.9
          bias: inverse
          rationale: Rural demand and discretionary spend soften
        IT:
          multiplier: 0.7
          bias: aligned
          rationale: Low direct impact; potential INR support
    - id: macro_rbi_repo_cut
      name: RBI Repo Rate Cut
      seasonal_activation: false
      keywords:
      - repo rate cut
      - rbi cuts repo
      - dovish rbi
      - rate decrease
      base_impact:
        mild: 0.25
        normal: 0.55
        severe: 0.85
      default_impact: normal
      market_weight: 0.9
      event_volatility: null
      volatility_sensitive: false
      contextual_modifiers:
      - keywords:
        - surprise
        - unexpected
        impact_level: severe
      sector_impacts:
        Financial Services:
          multiplier: 1.15
          bias: aligned
          beta_override: 1.25
          rationale: Funding costs fall; margins expand
        Banks:
          multiplier: 1.15
          bias: aligned
          beta_override: 1.25
          rationale: Funding costs fall; margins expand
        NBFC:
          multiplier: 1.15
          bias: aligned
          beta_override: 1.25
          rationale: Funding costs fall; margins expand
        Realty:
          multiplier: 1.25
          bias: aligned
          rationale: Lower borrowing costs stimulate demand
