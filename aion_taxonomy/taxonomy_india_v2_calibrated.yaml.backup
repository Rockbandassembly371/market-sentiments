metadata:
  version: 2.0.0
  market: INDIA_EQUITY
  last_updated: '2026-03-26'
  description: Deterministic taxonomy for Indian equity sentiment classification with
    sector-aware impact scoring
  scoring_formula: macro_signal = base_impact × market_weight; sector_signal = macro_signal
    × sector_multiplier × sector_bias_sign; confidence = weighted_linear(model_probability,
    taxonomy_match, data_quality, agreement_score)
  flip_rule: sector_flip_allowed IF abs(macro_signal) < (event_volatility × sector_beta)
  impact_selection: context_keywords select from [mild, normal, severe] fixed impact
    values — NO multiplication
  calibration:
    status: pending
    dataset_size: null
    last_calibrated: null
  dependencies:
  - aion-sectormap>=1.0
  - aion-sentiment-in>=2.3
config:
  impact_scale:
    POSITIVE: 1.0
    NEUTRAL: 0.0
    NEGATIVE: -1.0
  market_weight_max: 1.0
  flip_threshold:
    method: dynamic
    formula: event_volatility × sector_beta
    fallback_static: 0.35
  confidence_method: weighted_linear
  confidence_bounds:
  - 0
  - 1
  confidence_weights:
    model_probability: 0.4
    taxonomy_match: 0.3
    data_quality: 0.2
    agreement_score: 0.1
sectors:
- id: Financial Services
  beta_default: 1.1
- id: Banks
  beta_default: 1.15
- id: NBFC
  beta_default: 1.2
- id: IT
  beta_default: 0.9
- id: Healthcare
  beta_default: 0.8
