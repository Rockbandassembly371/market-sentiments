# Include README and LICENSE
include README.md
include LICENSE
include requirements.txt
include requirements-dev.txt
include pyproject.toml
include setup.py
include example.py

# Include package files
recursive-include src *.py
recursive-include src *.typed

# Include lexicon files (bundled NRC Emotion Lexicon)
recursive-include src/aion_sentiment/lexicons *.txt

# Include test files
recursive-include tests *.py

# Include data directory structure
include data/.gitkeep

# Exclude cache and build files
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
global-exclude .git
global-exclude .gitignore
global-exclude .DS_Store
global-exclude *.egg-info
global-exclude build
global-exclude dist
